digraph fig4_3_paper_4_offline_detection {
  graph [charset="UTF-8", rankdir="TB", splines="ortho", nodesep="0.25", ranksep="0.35", dpi="160", bgcolor="white", label="图4.3-4 数据上传与检测任务流程图", labelloc="t", fontsize="18", fontname="Microsoft YaHei"];
  node [fontname="Microsoft YaHei", fontsize="11", margin="0.12,0.08"];
  edge [fontname="Microsoft YaHei", fontsize="10", color="#566573", arrowhead="vee"];
  start [label="选择模型与CSV", shape="ellipse", style="filled", fillcolor="#E8F8F5", color="#16A085", penwidth="1.5"];
  task [label="创建检测任务", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  async [label="后台异步执行", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  prep [label="数据预处理", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  infer [label="模型推理", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  save [label="保存结果与告警", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  detail [label="展示检测详情", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  end [label="结束", shape="ellipse", style="filled", fillcolor="#E8F8F5", color="#16A085", penwidth="1.5"];
  start -> task [label="上传提交"];
  task -> async;
  async -> prep;
  prep -> infer;
  infer -> save;
  save -> detail;
  detail -> end;
}