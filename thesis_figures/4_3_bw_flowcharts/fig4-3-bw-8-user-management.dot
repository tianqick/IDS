digraph fig4_3_bw_8_user_management {
  graph [charset="UTF-8", rankdir="TB", splines="ortho", nodesep="0.28", ranksep="0.32", dpi="160", bgcolor="white", style="filled", fillcolor="white", pad="0.08", margin="0.04"];
  node [fontname="SimSun", fontsize="12", margin="0.10,0.07", fontcolor="#222222"];
  edge [fontname="SimSun", fontsize="11", color="#222222", fontcolor="#222222", arrowhead="normal", arrowsize="0.7", penwidth="1.1"];
  start [label="进入用户管理", shape="box", style="rounded", color="#222222", penwidth="1.4"];
  op [label="新增/编辑/删除", shape="box", style="", color="#222222", penwidth="1.2"];
  check [label="校验账号与角色", shape="diamond", style="", color="#222222", penwidth="1.2"];
  save [label="保存用户信息", shape="box", style="", color="#222222", penwidth="1.2"];
  log [label="记录操作日志", shape="box", style="", color="#222222", penwidth="1.2"];
  end [label="结束", shape="box", style="rounded", color="#222222", penwidth="1.4"];
  start -> op;
  op -> check;
  check -> op [xlabel="不通过"];
  check -> save [xlabel="通过"];
  save -> log;
  log -> end;
