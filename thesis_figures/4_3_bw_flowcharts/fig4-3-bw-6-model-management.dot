digraph fig4_3_bw_6_model_management {
  graph [charset="UTF-8", rankdir="TB", splines="ortho", nodesep="0.28", ranksep="0.32", dpi="160", bgcolor="white", style="filled", fillcolor="white", pad="0.08", margin="0.04"];
  node [fontname="SimSun", fontsize="12", margin="0.10,0.07", fontcolor="#222222"];
  edge [fontname="SimSun", fontsize="11", color="#222222", fontcolor="#222222", arrowhead="normal", arrowsize="0.7", penwidth="1.1"];
  start [label="进入模型管理", shape="box", style="rounded", color="#222222", penwidth="1.4"];
  meta [label="登记模型信息", shape="box", style="", color="#222222", penwidth="1.2"];
  check [label="校验模型文件", shape="diamond", style="", color="#222222", penwidth="1.2"];
  active [label="设置启用模型", shape="box", style="", color="#222222", penwidth="1.2"];
  detect [label="供检测任务调用", shape="box", style="", color="#222222", penwidth="1.2"];
  cap [label="展示模型能力", shape="box", style="", color="#222222", penwidth="1.2"];
  end [label="结束", shape="box", style="rounded", color="#222222", penwidth="1.4"];
  start -> meta;
  meta -> check;
  check -> meta [xlabel="不通过"];
  check -> active [xlabel="通过"];
  active -> detect;
  detect -> cap;
  cap -> end;
}