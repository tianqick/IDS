digraph fig4_3_bw_7_traffic_monitoring {
  graph [charset="UTF-8", rankdir="TB", splines="ortho", nodesep="0.28", ranksep="0.32", dpi="160", bgcolor="white", style="filled", fillcolor="white", pad="0.08", margin="0.04"];
  node [fontname="SimSun", fontsize="12", margin="0.10,0.07", fontcolor="#222222"];
  edge [fontname="SimSun", fontsize="11", color="#222222", fontcolor="#222222", arrowhead="normal", arrowsize="0.7", penwidth="1.1"];
  start [label="配置网卡参数", shape="box", style="rounded", color="#222222", penwidth="1.4"];
  run [label="启动监测线程", shape="box", style="", color="#222222", penwidth="1.2"];
  pcap [label="抓取PCAP", shape="box", style="", color="#222222", penwidth="1.2"];
  csv [label="提取流量特征", shape="box", style="", color="#222222", penwidth="1.2"];
  norm [label="规范化字段", shape="box", style="", color="#222222", penwidth="1.2"];
  detect [label="调用模型检测", shape="box", style="", color="#222222", penwidth="1.2"];
  archive [label="保存结果并归档", shape="box", style="", color="#222222", penwidth="1.2"];
  loop [label="继续监测？", shape="diamond", style="", color="#222222", penwidth="1.2"];
  end [label="停止监测", shape="box", style="rounded", color="#222222", penwidth="1.4"];
  start -> run;
  run -> pcap;
  pcap -> csv;
  csv -> norm;
  norm -> detect;
  detect -> archive;
  archive -> loop;
  loop -> pcap [xlabel="是"];
  loop -> end [xlabel="否"];
}