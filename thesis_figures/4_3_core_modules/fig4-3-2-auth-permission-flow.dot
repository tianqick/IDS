digraph fig4_3_2_auth_permission_flow {
  graph [charset="UTF-8", rankdir="TB", splines="ortho", nodesep="0.5", ranksep="0.7", dpi="160", bgcolor="white", label="图4.3-2 登录认证与权限控制流程图", labelloc="t", fontsize="18", fontname="Microsoft YaHei"];
  node [fontname="Microsoft YaHei", fontsize="11", margin="0.12,0.08"];
  edge [fontname="Microsoft YaHei", fontsize="10", color="#566573", arrowhead="vee"];
  start [label="用户访问系统", shape="ellipse", style="filled", fillcolor="#E8F8F5", color="#16A085", penwidth="1.5"];
  me [label="GET /api/auth/me\n检查会话状态", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  has_session [label="Session有效？", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  login_page [label="显示登录页\n输入用户名和密码", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  login [label="POST /api/auth/login\n提交认证信息", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  verify [label="用户名和密码\n校验通过？", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  fail [label="返回401\n提示错误", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  session [label="写入Session\nuser_id / username / role", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  log [label="写入operation_log\n登录操作日志", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  role [label="判断用户角色", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  admin [label="管理员视图\n完整管理功能", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  normal [label="普通用户视图\n检测与结果查询", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  api [label="访问业务API", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  guard [label="login_required /\nadmin_required校验", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  execute [label="执行请求并返回数据", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  reject [label="返回401/403\n拒绝访问", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  end [label="流程结束", shape="ellipse", style="filled", fillcolor="#E8F8F5", color="#16A085", penwidth="1.5"];
  start -> me;
  me -> has_session;
  has_session -> role [label="是"];
  has_session -> login_page [label="否"];
  login_page -> login;
  login -> verify;
  verify -> fail [label="否"];
  fail -> login_page;
  verify -> session [label="是"];
  session -> log;
  log -> role;
  role -> admin [label="admin"];
  role -> normal [label="user"];
  admin -> api;
  normal -> api;
  api -> guard;
  guard -> execute [label="通过"];
  guard -> reject [label="不通过"];
  execute -> end;
  reject -> login_page [label="需重新登录"];
}