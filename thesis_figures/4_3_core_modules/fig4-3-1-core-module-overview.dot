digraph fig4_3_1_core_module_overview {
  graph [charset="UTF-8", rankdir="TB", splines="ortho", nodesep="0.5", ranksep="0.7", dpi="160", bgcolor="white", label="图4.3-1 核心功能模块划分图", labelloc="t", fontsize="18", fontname="Microsoft YaHei"];
  node [fontname="Microsoft YaHei", fontsize="11", margin="0.12,0.08"];
  edge [fontname="Microsoft YaHei", fontsize="10", color="#566573", arrowhead="vee"];
  start [label="基于深度学习的\n网络入侵检测系统", shape="ellipse", style="filled", fillcolor="#E8F8F5", color="#16A085", penwidth="1.5"];
  common [label="通用支撑功能", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  business [label="核心检测业务", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  admin_domain [label="系统管理功能", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  auth [label="登录认证与\n权限控制", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  dashboard [label="系统首页与\n统计展示", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  upload [label="数据上传与\n后台检测任务", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  result [label="检测结果与\n历史记录", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  alarm [label="告警管理", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  model [label="模型管理与\n模型能力展示", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  traffic [label="实时流量监测", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  user [label="用户管理与\n操作审计", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  start -> common;
  start -> business;
  start -> admin_domain;
  common -> auth;
  common -> dashboard;
  business -> upload;
  business -> result;
  business -> alarm;
  business -> traffic;
  admin_domain -> model;
  admin_domain -> user;
}