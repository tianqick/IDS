digraph fig4_3_12_user_management_flow {
  graph [charset="UTF-8", rankdir="TB", splines="ortho", nodesep="0.5", ranksep="0.7", dpi="160", bgcolor="white", label="图4.3-12 用户管理与操作审计流程图", labelloc="t", fontsize="18", fontname="Microsoft YaHei"];
  node [fontname="Microsoft YaHei", fontsize="11", margin="0.12,0.08"];
  edge [fontname="Microsoft YaHei", fontsize="10", color="#566573", arrowhead="vee"];
  start [label="管理员进入用户管理", shape="ellipse", style="filled", fillcolor="#E8F8F5", color="#16A085", penwidth="1.5"];
  list [label="GET /api/users\n加载用户列表", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  db_list [label="查询user表\n按create_time降序", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  render [label="展示用户名/角色/创建时间", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  action [label="管理员操作？", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  create [label="POST /api/users\n新增用户", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  edit [label="PATCH /api/users/<id>\n修改用户名/角色/密码", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  valid [label="用户名非空且唯一\n角色为admin/user\n新增密码非空？", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  hash [label="hash_password()\n生成安全密码哈希", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  save [label="写入或更新user表\n写operation_log", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  sync [label="若修改当前账号\n同步刷新Session", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  delete [label="DELETE /api/users/<id>", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  self [label="是否删除当前账号？", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  records [label="是否存在检测记录？", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  block [label="阻止删除并提示原因", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  remove [label="删除user记录\n写operation_log", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  end [label="用户管理完成", shape="ellipse", style="filled", fillcolor="#E8F8F5", color="#16A085", penwidth="1.5"];
  start -> list;
  list -> db_list;
  db_list -> render;
  render -> action;
  action -> create [label="新增"];
  action -> edit [label="编辑"];
  action -> delete [label="删除"];
  action -> end [label="浏览"];
  create -> valid;
  edit -> valid;
  valid -> render [label="不通过"];
  valid -> hash [label="通过且需设密码"];
  hash -> save;
  valid -> save [label="通过且不改密码"];
  save -> sync;
  sync -> list [label="刷新"];
  delete -> self;
  self -> block [label="是"];
  self -> records [label="否"];
  records -> block [label="是"];
  records -> remove [label="否"];
  block -> render;
  remove -> list [label="刷新"];
}