digraph fig4_3_8_model_management_flow {
  graph [charset="UTF-8", rankdir="TB", splines="ortho", nodesep="0.5", ranksep="0.7", dpi="160", bgcolor="white", label="图4.3-8 模型管理流程图", labelloc="t", fontsize="18", fontname="Microsoft YaHei"];
  node [fontname="Microsoft YaHei", fontsize="11", margin="0.12,0.08"];
  edge [fontname="Microsoft YaHei", fontsize="10", color="#566573", arrowhead="vee"];
  start [label="管理员进入模型管理", shape="ellipse", style="filled", fillcolor="#E8F8F5", color="#16A085", penwidth="1.5"];
  list [label="GET /api/models\n加载模型与active_model_id", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  db_list [label="查询model_info\n激活模型优先排序", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  render [label="展示模型列表\n指标/路径/字段/启用状态", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  action [label="管理员操作？", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  create [label="POST /api/models\n新增模型元数据\n可上传.pth文件", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  validate [label="校验名称/路径/格式\n路径存在且不重复", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  insert [label="写入model_info\n保存指标和字段要求", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  active [label="需要设为启用？", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  set_active [label="set_active_model()\n取消其他模型启用\n设置唯一激活模型", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  activate [label="POST /api/models/<id>/activate\n切换启用模型", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  delete [label="DELETE /api/models/<id>\n删除模型", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  dep [label="存在任务或记录引用？", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  block [label="阻止删除\n避免历史数据失去模型来源", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  oplog [label="写入operation_log", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  end [label="模型管理完成", shape="ellipse", style="filled", fillcolor="#E8F8F5", color="#16A085", penwidth="1.5"];
  start -> list;
  list -> db_list;
  db_list -> render;
  render -> action;
  action -> create [label="新增"];
  action -> activate [label="启用"];
  action -> delete [label="删除"];
  action -> end [label="浏览"];
  create -> validate;
  validate -> render [label="不通过"];
  validate -> insert [label="通过"];
  insert -> active;
  active -> set_active [label="是"];
  active -> oplog [label="否"];
  set_active -> oplog;
  activate -> set_active;
  delete -> dep;
  dep -> block [label="是"];
  dep -> oplog [label="否，删除记录"];
  block -> render;
  oplog -> list [label="刷新"];
}