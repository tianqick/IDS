digraph fig4_3_5_background_detection_pipeline {
  graph [charset="UTF-8", rankdir="TB", splines="ortho", nodesep="0.5", ranksep="0.7", dpi="160", bgcolor="white", label="图4.3-5 后台检测与模型推理流程图", labelloc="t", fontsize="18", fontname="Microsoft YaHei"];
  node [fontname="Microsoft YaHei", fontsize="11", margin="0.12,0.08"];
  edge [fontname="Microsoft YaHei", fontsize="10", color="#566573", arrowhead="vee"];
  start [label="后台线程开始执行", shape="ellipse", style="filled", fillcolor="#E8F8F5", color="#16A085", penwidth="1.5"];
  running [label="更新任务状态\nstatus=running", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  resolve [label="get_model_for_detection()\n确定模型ID和路径", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  service [label="初始化ModelService\n加载预处理元数据和.pth权重", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  record [label="创建detect_record\n记录检测容器", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  chunk [label="按块读取CSV\nchunksize=5000", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  prepare [label="列名清洗\n删除非特征列\n缺失值填充", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  scale [label="按preprocess_meta\n执行Z-Score标准化\n重构为特征数×1张量", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  infer [label="PyTorch批量推理\nbatch_size=1024", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  label [label="softmax + argmax\n映射BENIGN或攻击类型\n计算风险等级", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  buffer [label="缓存AttackResult\n攻击样本同步缓存AlarmLog", shape="box", style="rounded,filled", fillcolor="#EBF5FB", color="#2874A6", penwidth="1.2"];
  flush [label="达到DB_BATCH_SIZE？", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  write [label="bulk_insert_mappings\n批量写入数据库", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  progress [label="progress_callback\n更新processed_rows", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  more [label="还有数据块？", shape="diamond", style="filled", fillcolor="#FEF5E7", color="#D68910", penwidth="1.2"];
  summary [label="更新detect_record\nsample/normal/attack统计", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  complete [label="任务completed\n或异常failed", shape="cylinder", style="filled", fillcolor="#F4ECF7", color="#7D3C98", penwidth="1.2"];
  end [label="后台检测结束", shape="ellipse", style="filled", fillcolor="#E8F8F5", color="#16A085", penwidth="1.5"];
  start -> running;
  running -> resolve;
  resolve -> service;
  service -> record;
  record -> chunk;
  chunk -> prepare;
  prepare -> scale;
  scale -> infer;
  infer -> label;
  label -> buffer;
  buffer -> flush;
  flush -> write [label="是"];
  flush -> progress [label="否"];
  write -> progress;
  progress -> more;
  more -> chunk [label="是"];
  more -> summary [label="否"];
  summary -> complete;
  complete -> end;
}